{
  "$schema": "https://ramams06.github.io/btech-registry/schema/registry-item.json",
  "name": "avatar",
  "type": "registry:ui",
  "title": "BTAvatar",
  "description": "Circular badge displaying a user's profile image or auto-derived initials. Supports skeleton loading state and explicit error state. Used standalone or inside BTAvatarGroup for stacked group displays.",
  "framework": "vue",
  "category": "molecules",
  "figmaUrl": "https://www.figma.com/design/WANr9drWYNYbMPuT2sMeHi/Btech---Design-System?node-id=497-979",
  "figmaNodeId": "497:979",
