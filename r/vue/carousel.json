      "path": "BTCarousel.css",
      "target": "@ui/carousel/BTCarousel.css",
      "type": "registry:ui",
      "content": "/* BTCarousel — Figma 2344-1404 (D-Carousel).\r\n * Two variants: horizontal (left/right nav) and vertical (up/down nav).\r\n * Shared between Vue and React.\r\n *\r\n * Architecture:\r\n *   .bt-carousel                      root flex container\r\n *   .bt-carousel--horizontal          row layout\r\n *   .bt-carousel--vertical            column layout\r\n *   .bt-carousel--ready               enables CSS transition (added after first paint)\r\n *   .bt-carousel__viewport            overflow:hidden clipping window\r\n *   .bt-carousel__track               the sliding flex container\r\n *   .bt-carousel__slide               individual slide (BTCarouselItem)\r\n *   .bt-carousel__btn                 nav button (prev / next)\r\n *   .bt-carousel__btn--prev           prev direction\r\n *   .bt-carousel__btn--next           next direction\r\n *   .bt-carousel__indicators          dot row — absolute inside viewport\r\n *   .bt-carousel__dot                 single indicator dot\r\n *   .bt-carousel__dot--active         active dot (wider + brand-primary)\r\n */\r\n\r\n/* ── Root ─────────────────────────────────────────────────────────── */\r\n\r\n.bt-carousel {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-xs); /* Figma: spacing.xs */\r\n  position: relative;\r\n}\r\n\r\n.bt-carousel--horizontal {\r\n  flex-direction: row;\r\n}\r\n\r\n.bt-carousel--vertical {\r\n  flex-direction: column;\r\n  height: 100%;         /* fill parent — parent must set explicit height */\r\n  align-items: stretch; /* viewport stretches to full width */\r\n}\r\n\r\n/* ── Viewport — overflow:hidden clipping window ─────────────────── */\r\n\r\n.bt-carousel__viewport {\r\n  flex: 1;\r\n  overflow: hidden;\r\n  min-width: 0;\r\n  position: relative; /* anchor for indicator dots */\r\n  cursor: grab;\r\n}\r\n\r\n.bt-carousel--dragging {\r\n  user-select: none;\r\n}\r\n\r\n.bt-carousel--dragging .bt-carousel__viewport {\r\n  cursor: grabbing;\r\n}\r\n\r\n/* ── Track — the sliding flex container ─────────────────────────── */\r\n\r\n.bt-carousel__track {\r\n  display: flex;\r\n  gap: var(--space-xs);\r\n  will-change: transform;\r\n}\r\n\r\n/* Transition enabled only after first paint (avoids initial flash) */\r\n.bt-carousel--ready .bt-carousel__track {\r\n  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n\r\n.bt-carousel--horizontal .bt-carousel__track {\r\n  flex-direction: row;\r\n}\r\n\r\n.bt-carousel--vertical .bt-carousel__track {\r\n  flex-direction: column;\r\n}\r\n\r\n/* ── Slide — individual item slot ───────────────────────────────── */\r\n\r\n.bt-carousel__slide {\r\n  flex: none;\r\n  /* Width set via --_bt-carousel-slide-w CSS custom property (set from JS) */\r\n  width: var(--_bt-carousel-slide-w, 100%);\r\n  box-sizing: border-box;\r\n  overflow: hidden; /* clip slide content to wrapper bounds */\r\n}\r\n\r\n.bt-carousel--vertical .bt-carousel__slide {\r\n  width: 100%;\r\n  height: var(--_bt-carousel-slide-h, auto);\r\n}\r\n\r\n/* ── Navigation button wrapper ───────────────────────────────────── */\r\n/*\r\n * BTButton (secondary-light, sm, iconOnly) is used as the nav control.\r\n * The wrapper clips it to a full-pill circle and provides flex sizing.\r\n */\r\n\r\n.bt-carousel__btn-wrap {\r\n  flex-shrink: 0;\r\n  display: inline-flex;\r\n  border-radius: var(--radius-rd); /* clips inner BTButton background to circle */\r\n  overflow: hidden;\r\n}\r\n\r\n/* Match inner BTButton's border-radius so its focus ring is also circular */\r\n.bt-carousel__btn-wrap .bt-button {\r\n  border-radius: var(--radius-rd);\r\n}\r\n\r\n/* Vertical: center nav wrappers horizontally */\r\n.bt-carousel--vertical .bt-carousel__btn-wrap {\r\n  align-self: center;\r\n}\r\n\r\n/* Vertical: allow viewport to shrink below its content height in flex column */\r\n.bt-carousel--vertical .bt-carousel__viewport {\r\n  min-height: 0;\r\n}\r\n\r\n/* RTL: flip horizontal chevrons */\r\n[dir=\"rtl\"] .bt-carousel--horizontal .bt-carousel__btn-wrap svg {\r\n  transform: scaleX(-1);\r\n}\r\n\r\n/* ── Dot indicators — absolute inside viewport ───────────────────── */\r\n\r\n.bt-carousel__indicators {\r\n  position: absolute;\r\n  bottom: var(--space-sm);\r\n  /* RTL-safe centering: span full width and use justify-content */\r\n  left: 0;\r\n  right: 0;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--space-2xs);\r\n  z-index: 10;\r\n  pointer-events: none;\r\n}\r\n\r\n.bt-carousel__dot {\r\n  flex-shrink: 0;\r\n  height: 4px;\r\n  border-radius: var(--radius-sm);\r\n  background: var(--icon-tertiary);\r\n  transition:\r\n    width 0.22s cubic-bezier(0.4, 0, 0.2, 1),\r\n    background 0.22s ease;\r\n  width: 4px;\r\n}\r\n\r\n.bt-carousel__dot--active {\r\n  width: 12px;\r\n  background: var(--color-brand-primary);\r\n}\r\n"
    },
