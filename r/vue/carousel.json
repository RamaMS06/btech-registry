      "path": "BTCarousel.vue",
      "target": "@ui/carousel/BTCarousel.vue",
      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\r\n/**\r\n * BTCarousel — horizontal or vertical sliding carousel.\r\n * Figma: node 2344-1404 (D-Carousel).\r\n * Web only — no Flutter implementation shares this file.\r\n *\r\n * Composes:\r\n *   BTCarouselItem — individual slide wrapper (default slot children).\r\n *\r\n * @example\r\n * ```vue\r\n * <BTCarousel v-model:activeIndex=\"idx\" variant=\"horizontal\">\r\n *   <BTCarouselItem v-for=\"item in items\" :key=\"item.id\">\r\n *     <img :src=\"item.src\" :alt=\"item.alt\" style=\"width:100%\" />\r\n *   </BTCarouselItem>\r\n * </BTCarousel>\r\n * ```\r\n */\r\nimport './BTCarousel.css';\r\nimport BTButton from '../button/BTButton.vue';\r\nimport {\r\n  Comment,\r\n  Fragment,\r\n  computed,\r\n  onMounted,\r\n  onUnmounted,\r\n  ref,\r\n  useSlots,\r\n  watch,\r\n  type VNode,\r\n} from 'vue';\r\n\r\n// ── SVG icon paths (Material Icons, 24×24 viewBox) ───────────────────\r\n\r\nconst ICON_CHEVRON_LEFT  = 'M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z';\r\nconst ICON_CHEVRON_RIGHT = 'M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z';\r\nconst ICON_ARROW_UP      = 'M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z';\r\nconst ICON_ARROW_DOWN    = 'M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z';\r\n\r\nconst GAP_PX     = 4;  // matches .bt-carousel__track gap\r\nconst PEEK_PX    = 32; // horizontal: pixels visible on each side (left + right)\r\nconst PEEK_BOTTOM = 32; // vertical: pixels of next slide visible at bottom only\r\n\r\n// ── Props ─────────────────────────────────────────────────────────────\r\n\r\nconst props = withDefaults(defineProps<{\r\n  variant?: 'horizontal' | 'vertical';\r\n  activeIndex?: number;\r\n  initialIndex?: number;\r\n  loop?: boolean;\r\n  showButtons?: boolean;\r\n  showIndicators?: boolean;\r\n  /**\r\n   * Automatically advance to the next slide on a timer.\r\n   * Pauses while the pointer is over the carousel or during a swipe.\r\n   * @default false\r\n   */\r\n  autoPlay?: boolean;\r\n  /**\r\n   * Milliseconds between auto-advances. Only used when `autoPlay` is `true`.\r\n   * @default 3000\r\n   */\r\n  autoPlayInterval?: number;\r\n}>(), {\r\n  variant: 'horizontal',\r\n  initialIndex: 0,\r\n  loop: false,\r\n  showButtons: true,\r\n  showIndicators: true,\r\n  autoPlay: false,\r\n  autoPlayInterval: 3000,\r\n});\r\n\r\nconst emit = defineEmits<{\r\n  'update:activeIndex': [index: number];\r\n  'change': [index: number];\r\n}>();\r\n\r\n// ── Slide count — derived from default slot VNodes ──────────────────\r\n\r\nconst slots = useSlots();\r\n\r\nfunction countNodes(nodes: VNode[]): number {\r\n  let count = 0;\r\n  for (const node of nodes) {\r\n    if (node.type === Fragment) {\r\n      count += countNodes((node.children as VNode[]) ?? []);\r\n    } else if (node.type !== Comment && typeof node.type !== 'symbol') {\r\n      count++;\r\n    }\r\n  }\r\n  return count;\r\n}\r\n\r\nconst slideCount = computed(() => countNodes(slots.default?.() ?? []));\r\n\r\n// ── Active index (controlled / uncontrolled) ───────────────────────────\r\n\r\nconst internalIndex = ref(props.initialIndex ?? 0);\r\n\r\nconst activeIndexValue = computed(() =>\r\n  props.activeIndex !== undefined ? props.activeIndex : internalIndex.value,\r\n);\r\n\r\nfunction goTo(next: number) {\r\n  const count = slideCount.value;\r\n  let target = next;\r\n  if (props.loop) {\r\n    target = ((next % count) + count) % count;\r\n  } else {\r\n    target = Math.max(0, Math.min(count - 1, next));\r\n  }\r\n  if (target === activeIndexValue.value) return;\r\n  internalIndex.value = target;\r\n  emit('update:activeIndex', target);\r\n  emit('change', target);\r\n}\r\n\r\nconst prev = () => goTo(activeIndexValue.value - 1);\r\nconst next = () => goTo(activeIndexValue.value + 1);\r\n\r\nconst atStart = computed(() => !props.loop && activeIndexValue.value === 0);\r\nconst atEnd   = computed(() => !props.loop && activeIndexValue.value >= slideCount.value - 1);\r\n\r\n// ── DOM refs + slide dimensions ────────────────────────────────────────\r\n\r\nconst rootEl    = ref<HTMLElement>();\r\nconst viewportRef = ref<HTMLElement>();\r\nconst slideW = ref(0);\r\nconst slideH = ref(0);\r\n\r\n// ── RTL detection ─────────────────────────────────────────────────────\r\nconst rtl = ref(false);\r\nfunction updateDir() {\r\n  rtl.value = !!rootEl.value && getComputedStyle(rootEl.value).direction === 'rtl';\r\n}\r\nconst _dirObserver = new MutationObserver(updateDir);\r\n\r\nfunction syncSize() {\r\n  const el = viewportRef.value;\r\n  if (!el) return;\r\n  if (isHorizontal.value) {\r\n    // Horizontal: shrink slide width → peek on both left and right edges.\r\n    slideW.value = el.clientWidth - 2 * PEEK_PX;\r\n    el.style.setProperty('--_bt-carousel-slide-w', `${slideW.value}px`);\r\n    el.style.setProperty('--_bt-carousel-slide-h', `${el.clientHeight}px`); // unused but harmless\r\n  } else {\r\n    // Vertical: shrink slide height only at the bottom → peek of next slide only.\r\n    // Slides start flush with the viewport top (no leading offset).\r\n    slideH.value = el.clientHeight - PEEK_BOTTOM;\r\n    el.style.setProperty('--_bt-carousel-slide-h', `${slideH.value}px`);\r\n    el.style.setProperty('--_bt-carousel-slide-w', `${el.clientWidth}px`); // unused (CSS overrides to 100%)\r\n  }\r\n}\r\n\r\nlet ro: ResizeObserver | null = null;\r\n\r\n// ── CSS transition readiness ────────────────────────────────────────────\r\n\r\nconst ready = ref(false);\r\n\r\nonMounted(() => {\r\n  syncSize();\r\n  ro = new ResizeObserver(syncSize);\r\n  if (viewportRef.value) ro.observe(viewportRef.value);\r\n  requestAnimationFrame(() => { ready.value = true; });\r\n  updateDir();\r\n  _dirObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['dir'] });\r\n});\r\n\r\nonUnmounted(() => {\r\n  ro?.disconnect();\r\n  _dirObserver.disconnect();\r\n  document.removeEventListener('mousemove', onMouseMove);\r\n  document.removeEventListener('mouseup', onMouseUp);\r\n});\r\n\r\n// ── Track transform ─────────────────────────────────────────────────────\r\n\r\nconst dragOffset  = ref(0);\r\nconst isDragging  = ref(false);\r\nconst isHorizontal = computed(() => props.variant === 'horizontal');\r\n\r\nconst trackStyle = computed(() => {\r\n  const slideSize = isHorizontal.value ? slideW.value : slideH.value;\r\n  const base  = isHorizontal.value\r\n    ? PEEK_PX - activeIndexValue.value * (slideSize + GAP_PX)\r\n    : -activeIndexValue.value * (slideSize + GAP_PX);\r\n  const total = base + dragOffset.value;\r\n  // RTL: flip horizontal track direction so slide 0 starts at the right\r\n  const physical = (isHorizontal.value && rtl.value) ? -total : total;\r\n  const axis  = isHorizontal.value ? 'X' : 'Y';\r\n  return {\r\n    transform: `translate${axis}(${physical}px)`,\r\n    transition: (isDragging.value || !ready.value) ? 'none' : undefined,\r\n  };\r\n});\r\n\r\n// ── Auto-play ────────────────────────────────────────────────────────────\r\n\r\nconst isPaused = ref(false);\r\nlet _autoPlayTimer: ReturnType<typeof setInterval> | null = null;\r\n\r\nfunction _stopAutoPlay() {\r\n  if (_autoPlayTimer !== null) {\r\n    clearInterval(_autoPlayTimer);\r\n    _autoPlayTimer = null;\r\n  }\r\n}\r\n\r\nfunction _startAutoPlay() {\r\n  _stopAutoPlay();\r\n  _autoPlayTimer = setInterval(() => {\r\n    if (isDragging.value || isPaused.value || atEnd.value) return;\r\n    next();\r\n  }, props.autoPlayInterval);\r\n}\r\n\r\n// Restart whenever autoPlay or autoPlayInterval changes.\r\nwatch(\r\n  () => [props.autoPlay, props.autoPlayInterval] as const,\r\n  ([enabled]) => {\r\n    if (enabled) _startAutoPlay();\r\n    else _stopAutoPlay();\r\n  },\r\n  { immediate: true },\r\n);\r\n\r\nonUnmounted(_stopAutoPlay);\r\n\r\n// ── Touch gesture (swipe) ───────────────────────────────────────────────\r\n\r\nlet touchStart = { x: 0, y: 0 };\r\n\r\nfunction onTouchStart(e: TouchEvent) {\r\n  const touch = e.touches[0];\r\n  if (!touch) return;\r\n  touchStart = { x: touch.clientX, y: touch.clientY };\r\n  isDragging.value = true;\r\n}\r\n\r\nfunction onTouchMove(e: TouchEvent) {\r\n  const touch = e.touches[0];\r\n  if (!touch) return;\r\n  const dx = touch.clientX - touchStart.x;\r\n  const dy = touch.clientY - touchStart.y;\r\n  // RTL: flip horizontal drag so swipe-right = next (matches visual direction)\r\n  dragOffset.value = isHorizontal.value ? (rtl.value ? -dx : dx) : dy;\r\n}\r\n\r\nfunction onTouchEnd() {\r\n  const threshold = 30;\r\n  if (dragOffset.value < -threshold) next();\r\n  else if (dragOffset.value > threshold) prev();\r\n  dragOffset.value = 0;\r\n  isDragging.value = false;\r\n}\r\n\r\n// ── Mouse wheel ─────────────────────────────────────────────────────────\r\n\r\nlet wheelTimeout: ReturnType<typeof setTimeout> | null = null;\r\n\r\nfunction onWheel(e: WheelEvent) {\r\n  e.preventDefault();\r\n  if (wheelTimeout) return;\r\n  const raw = isHorizontal.value ? (e.deltaX || e.deltaY) : e.deltaY;\r\n  // RTL: flip scroll direction for horizontal\r\n  const delta = (isHorizontal.value && rtl.value) ? -raw : raw;\r\n  if (delta > 0) next();\r\n  else if (delta < 0) prev();\r\n  wheelTimeout = setTimeout(() => { wheelTimeout = null; }, 400);\r\n}\r\n\r\n// ── Mouse drag ──────────────────────────────────────────────────────────\r\n\r\nlet mouseStart = { x: 0, y: 0 };\r\n\r\nfunction onMouseMove(e: MouseEvent) {\r\n  const dx = e.clientX - mouseStart.x;\r\n  const dy = e.clientY - mouseStart.y;\r\n  dragOffset.value = isHorizontal.value ? (rtl.value ? -dx : dx) : dy;\r\n}\r\n\r\nfunction onMouseUp() {\r\n  const threshold = 30;\r\n  if (dragOffset.value < -threshold) next();\r\n  else if (dragOffset.value > threshold) prev();\r\n  dragOffset.value = 0;\r\n  isDragging.value = false;\r\n  document.removeEventListener('mousemove', onMouseMove);\r\n  document.removeEventListener('mouseup', onMouseUp);\r\n}\r\n\r\nfunction onMouseDown(e: MouseEvent) {\r\n  if (e.button !== 0) return;\r\n  mouseStart = { x: e.clientX, y: e.clientY };\r\n  isDragging.value = true;\r\n  document.addEventListener('mousemove', onMouseMove);\r\n  document.addEventListener('mouseup', onMouseUp);\r\n}\r\n\r\n// ── Root class ──────────────────────────────────────────────────────────\r\n\r\nconst rootClass = computed(() =>\r\n  [\r\n    'bt-carousel',\r\n    `bt-carousel--${props.variant}`,\r\n    ready.value ? 'bt-carousel--ready' : '',\r\n    isDragging.value ? 'bt-carousel--dragging' : '',\r\n  ].filter(Boolean).join(' '),\r\n);\r\n\r\n// ── Icon paths ──────────────────────────────────────────────────────────\r\n\r\nconst prevIconPath = computed(() =>\r\n  isHorizontal.value ? ICON_CHEVRON_LEFT : ICON_ARROW_UP,\r\n);\r\nconst nextIconPath = computed(() =>\r\n  isHorizontal.value ? ICON_CHEVRON_RIGHT : ICON_ARROW_DOWN,\r\n);\r\n</script>\r\n\r\n<template>\r\n  <div\r\n    ref=\"rootEl\"\r\n    :class=\"rootClass\"\r\n    @mouseenter=\"isPaused = true\"\r\n    @mouseleave=\"isPaused = false\"\r\n  >\r\n\r\n    <!-- ── Prev button ────────────────────────────────────────── -->\r\n    <div v-if=\"showButtons\" class=\"bt-carousel__btn-wrap\">\r\n      <BTButton\r\n        variant=\"secondary-light\"\r\n        size=\"small\"\r\n        :icon-only=\"true\"\r\n        :disabled=\"atStart\"\r\n        :aria-label=\"isHorizontal ? 'Previous slide' : 'Previous'\"\r\n        @click=\"prev\"\r\n      >\r\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\r\n          <path :d=\"prevIconPath\" />\r\n        </svg>\r\n      </BTButton>\r\n    </div>\r\n\r\n    <!-- ── Viewport + track ───────────────────────────────────── -->\r\n    <div\r\n      ref=\"viewportRef\"\r\n      class=\"bt-carousel__viewport\"\r\n      @mousedown=\"onMouseDown\"\r\n      @touchstart.passive=\"onTouchStart\"\r\n      @touchmove.passive=\"onTouchMove\"\r\n      @touchend=\"onTouchEnd\"\r\n      @wheel.prevent=\"onWheel\"\r\n    >\r\n      <div class=\"bt-carousel__track\" :style=\"trackStyle\">\r\n        <!-- BTCarouselItem children -->\r\n        <slot />\r\n      </div>\r\n\r\n      <!-- ── Dot indicators ──────────────────────────────────── -->\r\n      <div\r\n        v-if=\"showIndicators && slideCount > 1\"\r\n        class=\"bt-carousel__indicators\"\r\n        aria-hidden=\"true\"\r\n      >\r\n        <span\r\n          v-for=\"i in slideCount\"\r\n          :key=\"i - 1\"\r\n          class=\"bt-carousel__dot\"\r\n          :class=\"{ 'bt-carousel__dot--active': i - 1 === activeIndexValue }\"\r\n        />\r\n      </div>\r\n    </div>\r\n\r\n    <!-- ── Next button ────────────────────────────────────────── -->\r\n    <div v-if=\"showButtons\" class=\"bt-carousel__btn-wrap\">\r\n      <BTButton\r\n        variant=\"secondary-light\"\r\n        size=\"small\"\r\n        :icon-only=\"true\"\r\n        :disabled=\"atEnd\"\r\n        :aria-label=\"isHorizontal ? 'Next slide' : 'Next'\"\r\n        @click=\"next\"\r\n      >\r\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\r\n          <path :d=\"nextIconPath\" />\r\n        </svg>\r\n      </BTButton>\r\n    </div>\r\n\r\n  </div>\r\n</template>\r\n"
    },
