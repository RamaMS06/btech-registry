      "target": "@ui/carousel/BTCarousel.types.ts",
      "type": "registry:ui",
      "content": "/**\r\n * BTCarousel public API types — shared between Vue SFC and type exports.\r\n *\r\n * Figma: node 2344-1404 (D-Carousel).\r\n * Web only (Vue + React). Flutter has its own Dart types.\r\n */\r\n\r\nexport type BTCarouselVariant = 'horizontal' | 'vertical';\r\n\r\nexport interface BTCarouselProps {\r\n  /**\r\n   * Layout direction.\r\n   * - `'horizontal'` — left/right navigation (default)\r\n   * - `'vertical'`   — up/down navigation\r\n   * @default 'horizontal'\r\n   */\r\n  variant?: BTCarouselVariant;\r\n\r\n  /**\r\n   * Controlled active slide index.\r\n   * Pair with `v-model:activeIndex` for controlled mode.\r\n   */\r\n  activeIndex?: number;\r\n\r\n  /**\r\n   * Initial active slide index for uncontrolled mode.\r\n   * @default 0\r\n   */\r\n  initialIndex?: number;\r\n\r\n  /**\r\n   * Loop back to first/last slide at boundaries.\r\n   * @default false\r\n   */\r\n  loop?: boolean;\r\n\r\n  /**\r\n   * Show previous/next navigation buttons.\r\n   * @default true\r\n   */\r\n  showButtons?: boolean;\r\n\r\n  /**\r\n   * Show dot indicators.\r\n   * @default true\r\n   */\r\n  showIndicators?: boolean;\r\n}\r\n\r\nexport interface BTCarouselItemProps {\r\n  /** Optional extra CSS class on the slide wrapper. */\r\n  class?: string;\r\n}\r\n"
    },
