      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\r\n/**\r\n * BTCarouselItem — individual slide wrapper for BTCarousel.\r\n *\r\n * Must be a direct child of BTCarousel. No props needed — wrap any content.\r\n *\r\n * @example\r\n * ```vue\r\n * <BTCarouselItem>\r\n *   <img src=\"/photo.jpg\" alt=\"Photo\" style=\"width:100%; height:200px; object-fit:cover\" />\r\n * </BTCarouselItem>\r\n * ```\r\n */\r\n// Pure slide wrapper — no injection needed.\r\n// BTCarousel counts visible slides via useSlots() internally.\r\n</script>\r\n\r\n<template>\r\n  <div class=\"bt-carousel__slide\">\r\n    <slot />\r\n  </div>\r\n</template>\r\n"
    },
    {
      "path": "index.ts",
      "target": "@ui/carousel/index.ts",
      "type": "registry:ui",
      "content": "export { default as BTCarousel } from './BTCarousel.vue';\r\nexport { default as BTCarouselItem } from './BTCarouselItem.vue';\r\nexport type {\r\n  BTCarouselProps,\r\n  BTCarouselItemProps,\r\n  BTCarouselVariant,\r\n} from './BTCarousel.types';\r\n"
    }
  ]
}