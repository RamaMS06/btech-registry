    {
      "path": "BTCarousel.css",
      "target": "@ui/carousel/BTCarousel.css",
      "type": "registry:ui",
      "content": "/* BTCarousel — Figma 2344-1404 (D-Carousel).\n * Two variants: horizontal (left/right nav) and vertical (up/down nav).\n * Shared between Vue and React.\n *\n * Architecture:\n *   .bt-carousel                      root flex container\n *   .bt-carousel--horizontal          row layout\n *   .bt-carousel--vertical            column layout\n *   .bt-carousel--ready               enables CSS transition (added after first paint)\n *   .bt-carousel__viewport            overflow:hidden clipping window\n *   .bt-carousel__track               the sliding flex container\n *   .bt-carousel__slide               individual slide (BTCarouselItem)\n *   .bt-carousel__btn                 nav button (prev / next)\n *   .bt-carousel__btn--prev           prev direction\n *   .bt-carousel__btn--next           next direction\n *   .bt-carousel__indicators          dot row — absolute inside viewport\n *   .bt-carousel__dot                 single indicator dot\n *   .bt-carousel__dot--active         active dot (wider + brand-primary)\n */\n\n/* ── Root ─────────────────────────────────────────────────────────── */\n\n.bt-carousel {\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs); /* Figma: spacing.xs */\n  position: relative;\n}\n\n.bt-carousel--horizontal {\n  flex-direction: row;\n}\n\n.bt-carousel--vertical {\n  flex-direction: column;\n  height: 100%;         /* fill parent — parent must set explicit height */\n  align-items: stretch; /* viewport stretches to full width */\n}\n\n/* ── Viewport — overflow:hidden clipping window ─────────────────── */\n\n.bt-carousel__viewport {\n  flex: 1;\n  overflow: hidden;\n  min-width: 0;\n  position: relative; /* anchor for indicator dots */\n  cursor: grab;\n}\n\n.bt-carousel--dragging {\n  user-select: none;\n}\n\n.bt-carousel--dragging .bt-carousel__viewport {\n  cursor: grabbing;\n}\n\n/* ── Track — the sliding flex container ─────────────────────────── */\n\n.bt-carousel__track {\n  display: flex;\n  gap: var(--space-xs);\n  will-change: transform;\n}\n\n/* Transition enabled only after first paint (avoids initial flash) */\n.bt-carousel--ready .bt-carousel__track {\n  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.bt-carousel--horizontal .bt-carousel__track {\n  flex-direction: row;\n}\n\n.bt-carousel--vertical .bt-carousel__track {\n  flex-direction: column;\n}\n\n/* ── Slide — individual item slot ───────────────────────────────── */\n\n.bt-carousel__slide {\n  flex: none;\n  /* Width set via --_bt-carousel-slide-w CSS custom property (set from JS) */\n  width: var(--_bt-carousel-slide-w, 100%);\n  box-sizing: border-box;\n  overflow: hidden; /* clip slide content to wrapper bounds */\n}\n\n.bt-carousel--vertical .bt-carousel__slide {\n  width: 100%;\n  height: var(--_bt-carousel-slide-h, auto);\n}\n\n/* ── Navigation button wrapper ───────────────────────────────────── */\n/*\n * BTButton (secondary-light, sm, iconOnly) is used as the nav control.\n * The wrapper clips it to a full-pill circle and provides flex sizing.\n */\n\n.bt-carousel__btn-wrap {\n  flex-shrink: 0;\n  display: inline-flex;\n  border-radius: var(--radius-rd); /* clips inner BTButton background to circle */\n  overflow: hidden;\n}\n\n/* Match inner BTButton's border-radius so its focus ring is also circular */\n.bt-carousel__btn-wrap .bt-button {\n  border-radius: var(--radius-rd);\n}\n\n/* Vertical: center nav wrappers horizontally */\n.bt-carousel--vertical .bt-carousel__btn-wrap {\n  align-self: center;\n}\n\n/* Vertical: allow viewport to shrink below its content height in flex column */\n.bt-carousel--vertical .bt-carousel__viewport {\n  min-height: 0;\n}\n\n/* RTL: flip horizontal chevrons */\n[dir=\"rtl\"] .bt-carousel--horizontal .bt-carousel__btn-wrap svg {\n  transform: scaleX(-1);\n}\n\n/* ── Dot indicators — absolute inside viewport ───────────────────── */\n\n.bt-carousel__indicators {\n  position: absolute;\n  bottom: var(--space-sm);\n  /* RTL-safe centering: span full width and use justify-content */\n  left: 0;\n  right: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--space-2xs);\n  z-index: 10;\n  pointer-events: none;\n}\n\n.bt-carousel__dot {\n  flex-shrink: 0;\n  height: 4px;\n  border-radius: var(--radius-sm);\n  background: var(--icon-tertiary);\n  transition:\n    width 0.22s cubic-bezier(0.4, 0, 0.2, 1),\n    background 0.22s ease;\n  width: 4px;\n}\n\n.bt-carousel__dot--active {\n  width: 12px;\n  background: var(--color-brand-primary);\n}\n"
    },
    {
      "path": "BTCarousel.types.ts",
      "target": "@ui/carousel/BTCarousel.types.ts",
      "type": "registry:ui",
      "content": "/**\n * BTCarousel public API types — shared between Vue SFC and type exports.\n *\n * Figma: node 2344-1404 (D-Carousel).\n * Web only (Vue + React). Flutter has its own Dart types.\n */\n\nexport type BTCarouselVariant = 'horizontal' | 'vertical';\n\nexport interface BTCarouselProps {\n  /**\n   * Layout direction.\n   * - `'horizontal'` — left/right navigation (default)\n   * - `'vertical'`   — up/down navigation\n   * @default 'horizontal'\n   */\n  variant?: BTCarouselVariant;\n\n  /**\n   * Controlled active slide index.\n   * Pair with `v-model:activeIndex` for controlled mode.\n   */\n  activeIndex?: number;\n\n  /**\n   * Initial active slide index for uncontrolled mode.\n   * @default 0\n   */\n  initialIndex?: number;\n\n  /**\n   * Loop back to first/last slide at boundaries.\n   * @default false\n   */\n  loop?: boolean;\n\n  /**\n   * Show previous/next navigation buttons.\n   * @default true\n   */\n  showButtons?: boolean;\n\n  /**\n   * Show dot indicators.\n   * @default true\n   */\n  showIndicators?: boolean;\n}\n\nexport interface BTCarouselItemProps {\n  /** Optional extra CSS class on the slide wrapper. */\n  class?: string;\n}\n"
    },
    {
      "path": "BTCarousel.vue",
      "target": "@ui/carousel/BTCarousel.vue",
      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\n/**\n * BTCarousel — horizontal or vertical sliding carousel.\n * Figma: node 2344-1404 (D-Carousel).\n * Web only — no Flutter implementation shares this file.\n *\n * Composes:\n *   BTCarouselItem — individual slide wrapper (default slot children).\n *\n * @example\n * ```vue\n * <BTCarousel v-model:activeIndex=\"idx\" variant=\"horizontal\">\n *   <BTCarouselItem v-for=\"item in items\" :key=\"item.id\">\n *     <img :src=\"item.src\" :alt=\"item.alt\" style=\"width:100%\" />\n *   </BTCarouselItem>\n * </BTCarousel>\n * ```\n */\nimport './BTCarousel.css';\nimport BTButton from '../button/BTButton.vue';\nimport {\n  Comment,\n  Fragment,\n  computed,\n  onMounted,\n  onUnmounted,\n  ref,\n  useSlots,\n  watch,\n  type VNode,\n} from 'vue';\n\n// ── SVG icon paths (Material Icons, 24×24 viewBox) ───────────────────\n\nconst ICON_CHEVRON_LEFT  = 'M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z';\nconst ICON_CHEVRON_RIGHT = 'M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z';\nconst ICON_ARROW_UP      = 'M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z';\nconst ICON_ARROW_DOWN    = 'M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z';\n\nconst GAP_PX     = 4;  // matches .bt-carousel__track gap\nconst PEEK_PX    = 32; // horizontal: pixels visible on each side (left + right)\nconst PEEK_BOTTOM = 32; // vertical: pixels of next slide visible at bottom only\n\n// ── Props ─────────────────────────────────────────────────────────────\n\nconst props = withDefaults(defineProps<{\n  variant?: 'horizontal' | 'vertical';\n  activeIndex?: number;\n  initialIndex?: number;\n  loop?: boolean;\n  showButtons?: boolean;\n  showIndicators?: boolean;\n  /**\n   * Automatically advance to the next slide on a timer.\n   * Pauses while the pointer is over the carousel or during a swipe.\n   * @default false\n   */\n  autoPlay?: boolean;\n  /**\n   * Milliseconds between auto-advances. Only used when `autoPlay` is `true`.\n   * @default 3000\n   */\n  autoPlayInterval?: number;\n}>(), {\n  variant: 'horizontal',\n  initialIndex: 0,\n  loop: false,\n  showButtons: true,\n  showIndicators: true,\n  autoPlay: false,\n  autoPlayInterval: 3000,\n});\n\nconst emit = defineEmits<{\n  'update:activeIndex': [index: number];\n  'change': [index: number];\n}>();\n\n// ── Slide count — derived from default slot VNodes ──────────────────\n\nconst slots = useSlots();\n\nfunction countNodes(nodes: VNode[]): number {\n  let count = 0;\n  for (const node of nodes) {\n    if (node.type === Fragment) {\n      count += countNodes((node.children as VNode[]) ?? []);\n    } else if (node.type !== Comment && typeof node.type !== 'symbol') {\n      count++;\n    }\n  }\n  return count;\n}\n\nconst slideCount = computed(() => countNodes(slots.default?.() ?? []));\n\n// ── Active index (controlled / uncontrolled) ───────────────────────────\n\nconst internalIndex = ref(props.initialIndex ?? 0);\n\nconst activeIndexValue = computed(() =>\n  props.activeIndex !== undefined ? props.activeIndex : internalIndex.value,\n);\n\nfunction goTo(next: number) {\n  const count = slideCount.value;\n  let target = next;\n  if (props.loop) {\n    target = ((next % count) + count) % count;\n  } else {\n    target = Math.max(0, Math.min(count - 1, next));\n  }\n  if (target === activeIndexValue.value) return;\n  internalIndex.value = target;\n  emit('update:activeIndex', target);\n  emit('change', target);\n}\n\nconst prev = () => goTo(activeIndexValue.value - 1);\nconst next = () => goTo(activeIndexValue.value + 1);\n\nconst atStart = computed(() => !props.loop && activeIndexValue.value === 0);\nconst atEnd   = computed(() => !props.loop && activeIndexValue.value >= slideCount.value - 1);\n\n// ── DOM refs + slide dimensions ────────────────────────────────────────\n\nconst rootEl    = ref<HTMLElement>();\nconst viewportRef = ref<HTMLElement>();\nconst slideW = ref(0);\nconst slideH = ref(0);\n\n// ── RTL detection ─────────────────────────────────────────────────────\nconst rtl = ref(false);\nfunction updateDir() {\n  rtl.value = !!rootEl.value && getComputedStyle(rootEl.value).direction === 'rtl';\n}\nconst _dirObserver = new MutationObserver(updateDir);\n\nfunction syncSize() {\n  const el = viewportRef.value;\n  if (!el) return;\n  if (isHorizontal.value) {\n    // Horizontal: shrink slide width → peek on both left and right edges.\n    slideW.value = el.clientWidth - 2 * PEEK_PX;\n    el.style.setProperty('--_bt-carousel-slide-w', `${slideW.value}px`);\n    el.style.setProperty('--_bt-carousel-slide-h', `${el.clientHeight}px`); // unused but harmless\n  } else {\n    // Vertical: shrink slide height only at the bottom → peek of next slide only.\n    // Slides start flush with the viewport top (no leading offset).\n    slideH.value = el.clientHeight - PEEK_BOTTOM;\n    el.style.setProperty('--_bt-carousel-slide-h', `${slideH.value}px`);\n    el.style.setProperty('--_bt-carousel-slide-w', `${el.clientWidth}px`); // unused (CSS overrides to 100%)\n  }\n}\n\nlet ro: ResizeObserver | null = null;\n\n// ── CSS transition readiness ────────────────────────────────────────────\n\nconst ready = ref(false);\n\nonMounted(() => {\n  syncSize();\n  ro = new ResizeObserver(syncSize);\n  if (viewportRef.value) ro.observe(viewportRef.value);\n  requestAnimationFrame(() => { ready.value = true; });\n  updateDir();\n  _dirObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['dir'] });\n});\n\nonUnmounted(() => {\n  ro?.disconnect();\n  _dirObserver.disconnect();\n  document.removeEventListener('mousemove', onMouseMove);\n  document.removeEventListener('mouseup', onMouseUp);\n});\n\n// ── Track transform ─────────────────────────────────────────────────────\n\nconst dragOffset  = ref(0);\nconst isDragging  = ref(false);\nconst isHorizontal = computed(() => props.variant === 'horizontal');\n\nconst trackStyle = computed(() => {\n  const slideSize = isHorizontal.value ? slideW.value : slideH.value;\n  const base  = isHorizontal.value\n    ? PEEK_PX - activeIndexValue.value * (slideSize + GAP_PX)\n    : -activeIndexValue.value * (slideSize + GAP_PX);\n  const total = base + dragOffset.value;\n  // RTL: flip horizontal track direction so slide 0 starts at the right\n  const physical = (isHorizontal.value && rtl.value) ? -total : total;\n  const axis  = isHorizontal.value ? 'X' : 'Y';\n  return {\n    transform: `translate${axis}(${physical}px)`,\n    transition: (isDragging.value || !ready.value) ? 'none' : undefined,\n  };\n});\n\n// ── Auto-play ────────────────────────────────────────────────────────────\n\nconst isPaused = ref(false);\nlet _autoPlayTimer: ReturnType<typeof setInterval> | null = null;\n\nfunction _stopAutoPlay() {\n  if (_autoPlayTimer !== null) {\n    clearInterval(_autoPlayTimer);\n    _autoPlayTimer = null;\n  }\n}\n\nfunction _startAutoPlay() {\n  _stopAutoPlay();\n  _autoPlayTimer = setInterval(() => {\n    if (isDragging.value || isPaused.value || atEnd.value) return;\n    next();\n  }, props.autoPlayInterval);\n}\n\n// Restart whenever autoPlay or autoPlayInterval changes.\nwatch(\n  () => [props.autoPlay, props.autoPlayInterval] as const,\n  ([enabled]) => {\n    if (enabled) _startAutoPlay();\n    else _stopAutoPlay();\n  },\n  { immediate: true },\n);\n\nonUnmounted(_stopAutoPlay);\n\n// ── Touch gesture (swipe) ───────────────────────────────────────────────\n\nlet touchStart = { x: 0, y: 0 };\n\nfunction onTouchStart(e: TouchEvent) {\n  const touch = e.touches[0];\n  if (!touch) return;\n  touchStart = { x: touch.clientX, y: touch.clientY };\n  isDragging.value = true;\n}\n\nfunction onTouchMove(e: TouchEvent) {\n  const touch = e.touches[0];\n  if (!touch) return;\n  const dx = touch.clientX - touchStart.x;\n  const dy = touch.clientY - touchStart.y;\n  // RTL: flip horizontal drag so swipe-right = next (matches visual direction)\n  dragOffset.value = isHorizontal.value ? (rtl.value ? -dx : dx) : dy;\n}\n\nfunction onTouchEnd() {\n  const threshold = 30;\n  if (dragOffset.value < -threshold) next();\n  else if (dragOffset.value > threshold) prev();\n  dragOffset.value = 0;\n  isDragging.value = false;\n}\n\n// ── Mouse wheel ─────────────────────────────────────────────────────────\n\nlet wheelTimeout: ReturnType<typeof setTimeout> | null = null;\n\nfunction onWheel(e: WheelEvent) {\n  e.preventDefault();\n  if (wheelTimeout) return;\n  const raw = isHorizontal.value ? (e.deltaX || e.deltaY) : e.deltaY;\n  // RTL: flip scroll direction for horizontal\n  const delta = (isHorizontal.value && rtl.value) ? -raw : raw;\n  if (delta > 0) next();\n  else if (delta < 0) prev();\n  wheelTimeout = setTimeout(() => { wheelTimeout = null; }, 400);\n}\n\n// ── Mouse drag ──────────────────────────────────────────────────────────\n\nlet mouseStart = { x: 0, y: 0 };\n\nfunction onMouseMove(e: MouseEvent) {\n  const dx = e.clientX - mouseStart.x;\n  const dy = e.clientY - mouseStart.y;\n  dragOffset.value = isHorizontal.value ? (rtl.value ? -dx : dx) : dy;\n}\n\nfunction onMouseUp() {\n  const threshold = 30;\n  if (dragOffset.value < -threshold) next();\n  else if (dragOffset.value > threshold) prev();\n  dragOffset.value = 0;\n  isDragging.value = false;\n  document.removeEventListener('mousemove', onMouseMove);\n  document.removeEventListener('mouseup', onMouseUp);\n}\n\nfunction onMouseDown(e: MouseEvent) {\n  if (e.button !== 0) return;\n  mouseStart = { x: e.clientX, y: e.clientY };\n  isDragging.value = true;\n  document.addEventListener('mousemove', onMouseMove);\n  document.addEventListener('mouseup', onMouseUp);\n}\n\n// ── Root class ──────────────────────────────────────────────────────────\n\nconst rootClass = computed(() =>\n  [\n    'bt-carousel',\n    `bt-carousel--${props.variant}`,\n    ready.value ? 'bt-carousel--ready' : '',\n    isDragging.value ? 'bt-carousel--dragging' : '',\n  ].filter(Boolean).join(' '),\n);\n\n// ── Icon paths ──────────────────────────────────────────────────────────\n\nconst prevIconPath = computed(() =>\n  isHorizontal.value ? ICON_CHEVRON_LEFT : ICON_ARROW_UP,\n);\nconst nextIconPath = computed(() =>\n  isHorizontal.value ? ICON_CHEVRON_RIGHT : ICON_ARROW_DOWN,\n);\n</script>\n\n<template>\n  <div\n    ref=\"rootEl\"\n    :class=\"rootClass\"\n    @mouseenter=\"isPaused = true\"\n    @mouseleave=\"isPaused = false\"\n  >\n\n    <!-- ── Prev button ────────────────────────────────────────── -->\n    <div v-if=\"showButtons\" class=\"bt-carousel__btn-wrap\">\n      <BTButton\n        variant=\"secondary-light\"\n        size=\"small\"\n        :icon-only=\"true\"\n        :disabled=\"atStart\"\n        :aria-label=\"isHorizontal ? 'Previous slide' : 'Previous'\"\n        @click=\"prev\"\n      >\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\n          <path :d=\"prevIconPath\" />\n        </svg>\n      </BTButton>\n    </div>\n\n    <!-- ── Viewport + track ───────────────────────────────────── -->\n    <div\n      ref=\"viewportRef\"\n      class=\"bt-carousel__viewport\"\n      @mousedown=\"onMouseDown\"\n      @touchstart.passive=\"onTouchStart\"\n      @touchmove.passive=\"onTouchMove\"\n      @touchend=\"onTouchEnd\"\n      @wheel.prevent=\"onWheel\"\n    >\n      <div class=\"bt-carousel__track\" :style=\"trackStyle\">\n        <!-- BTCarouselItem children -->\n        <slot />\n      </div>\n\n      <!-- ── Dot indicators ──────────────────────────────────── -->\n      <div\n        v-if=\"showIndicators && slideCount > 1\"\n        class=\"bt-carousel__indicators\"\n        aria-hidden=\"true\"\n      >\n        <span\n          v-for=\"i in slideCount\"\n          :key=\"i - 1\"\n          class=\"bt-carousel__dot\"\n          :class=\"{ 'bt-carousel__dot--active': i - 1 === activeIndexValue }\"\n        />\n      </div>\n    </div>\n\n    <!-- ── Next button ────────────────────────────────────────── -->\n    <div v-if=\"showButtons\" class=\"bt-carousel__btn-wrap\">\n      <BTButton\n        variant=\"secondary-light\"\n        size=\"small\"\n        :icon-only=\"true\"\n        :disabled=\"atEnd\"\n        :aria-label=\"isHorizontal ? 'Next slide' : 'Next'\"\n        @click=\"next\"\n      >\n        <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\">\n          <path :d=\"nextIconPath\" />\n        </svg>\n      </BTButton>\n    </div>\n\n  </div>\n</template>\n"
    },
    {
      "path": "BTCarouselItem.vue",
      "target": "@ui/carousel/BTCarouselItem.vue",
      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\n/**\n * BTCarouselItem — individual slide wrapper for BTCarousel.\n *\n * Must be a direct child of BTCarousel. No props needed — wrap any content.\n *\n * @example\n * ```vue\n * <BTCarouselItem>\n *   <img src=\"/photo.jpg\" alt=\"Photo\" style=\"width:100%; height:200px; object-fit:cover\" />\n * </BTCarouselItem>\n * ```\n */\n// Pure slide wrapper — no injection needed.\n// BTCarousel counts visible slides via useSlots() internally.\n</script>\n\n<template>\n  <div class=\"bt-carousel__slide\">\n    <slot />\n  </div>\n</template>\n"
    },
    {
      "path": "index.ts",
      "target": "@ui/carousel/index.ts",
      "type": "registry:ui",
      "content": "export { default as BTCarousel } from './BTCarousel.vue';\nexport { default as BTCarouselItem } from './BTCarouselItem.vue';\nexport type {\n  BTCarouselProps,\n  BTCarouselItemProps,\n  BTCarouselVariant,\n} from './BTCarousel.types';\n"
    }
  ]
}