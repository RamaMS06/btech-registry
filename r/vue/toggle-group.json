{
  "$schema": "https://ramams06.github.io/btech-registry/schema/registry-item.json",
  "name": "toggle-group",
  "type": "registry:ui",
  "title": "BTToggleGroup",
  "description": "Generic selection container that renders a row of BTToggle items. Manages single or multiple selection state internally and exposes it via controlled value + change event. Forwards variant, size, and disabled to all children.",
  "framework": "vue",
  "category": "atoms",
  "figmaUrl": "https://www.figma.com/design/WANr9drWYNYbMPuT2sMeHi/BTech-Design-System?node-id=2864-12585",
  "figmaNodeId": "2864-12585",
  "dependencies": [
    "@btech/tokens"
  ],
  "devDependencies": [],
  "registryDependencies": [],
  "files": [
    {
      "path": "BTToggleGroup.css",
      "target": "@ui/BTToggleGroup.css",
      "type": "registry:ui",
      "content": "/* BTToggleGroup styles — Figma 2864-12585.\n   All colors via @btech/tokens CSS vars — no hex fallbacks. */\n\n.bt-toggle-group {\n  display: flex;\n  align-items: center;\n  flex-wrap: wrap;\n  gap: var(--space-sm);\n}\n\n.bt-toggle-group--small {\n  gap: var(--space-xs);\n}\n"
    },
    {
      "path": "BTToggleGroup.types.ts",
      "target": "@ui/BTToggleGroup.types.ts",
      "type": "registry:ui",
      "content": "import type { BTToggleVariant, BTToggleSize } from '../Toggle/BTToggle.types';\n\nexport type { BTToggleVariant, BTToggleSize };\n\nexport interface BTToggleGroupItem<T = string> {\n  /** The value associated with this item — used for selection comparison. */\n  value: T;\n  /** Label shown in the toggle button. */\n  label: string;\n  /** When true, this item is disabled regardless of group disabled state. */\n  disabled?: boolean;\n}\n\nexport interface BTToggleGroupProps<T = string> {\n  /** List of toggle options to render. */\n  items: BTToggleGroupItem<T>[];\n  /** Selection mode. 'single': at most one active. 'multiple': any number. Default: 'single'. */\n  type?: 'single' | 'multiple';\n  /**\n   * Controlled selection value.\n   * - single mode: T | null\n   * - multiple mode: T[]\n   */\n  value?: T | T[] | null;\n  /** Visual style forwarded to all child toggles. Default: 'default'. */\n  variant?: BTToggleVariant;\n  /** Size forwarded to all child toggles. Default: 'default'. */\n  size?: BTToggleSize;\n  /** When true, the entire group is non-interactive. Default: false. */\n  disabled?: boolean;\n}\n"
    },
    {
      "path": "BTToggleGroup.vue",
      "target": "@ui/BTToggleGroup.vue",
      "type": "registry:ui",
      "content": "<!-- BTToggleGroup — selection-state container for BTToggle items.\n     Figma source: node 2864-12585.\n     Owns selection state internally. Exposes it via controlled `value` + `change` event.\n     Forwards `variant`, `size`, and `disabled` to all child toggles.\n\n     @example Single selection (default)\n     <BTToggleGroup :items=\"items\" :value=\"selected\" @change=\"v => selected = v as string | null\" />\n\n     @example Multiple selection\n     <BTToggleGroup type=\"multiple\" :items=\"items\" :value=\"selectedArr\" @change=\"v => selectedArr = v as string[]\" />\n\n     @example Outline variant, small size\n     <BTToggleGroup variant=\"outline\" size=\"small\" :items=\"items\" :value=\"sel\" @change=\"v => sel = v as string | null\" />\n-->\n<script setup lang=\"ts\" generic=\"T\">\nimport { ref, watch, computed } from 'vue';\nimport './BTToggleGroup.css';\nimport BTToggle from '../Toggle/BTToggle.vue';\nimport type { BTToggleGroupProps, BTToggleGroupItem } from './BTToggleGroup.types';\n\nconst props = withDefaults(defineProps<BTToggleGroupProps<T>>(), {\n  type:     'single',\n  variant:  'default',\n  size:     'default',\n  disabled: false,\n  value:    undefined,\n});\n\nconst emit = defineEmits<{\n  change: [value: T | T[] | null];\n}>();\n\n// Internal selection state — mirrors the controlled `value` prop.\nconst selected = ref<T | T[] | null>(\n  props.type === 'multiple'\n    ? ((props.value as T[] | undefined) ?? [])\n    : ((props.value as T | null | undefined) ?? null),\n) as import('vue').Ref<T | T[] | null>;\n\n// Sync internal state when the caller changes `value` externally.\nwatch(\n  () => props.value,\n  (newVal) => { selected.value = (newVal as T | T[] | null | undefined) ?? null; },\n);\n\nfunction isPressed(item: BTToggleGroupItem<T>): boolean {\n  if (props.type === 'multiple') {\n    return (selected.value as T[]).includes(item.value);\n  }\n  return selected.value === item.value;\n}\n\nfunction handleToggle(item: BTToggleGroupItem<T>) {\n  if (props.disabled || item.disabled) return;\n  let next: T | T[] | null;\n  if (props.type === 'multiple') {\n    const current = (selected.value as T[]) ?? [];\n    next = current.includes(item.value)\n      ? current.filter((v) => v !== item.value)\n      : [...current, item.value];\n  } else {\n    next = selected.value === item.value ? null : item.value;\n  }\n  selected.value = next;\n  emit('change', next);\n}\n\nconst groupClass = computed(() =>\n  ['bt-toggle-group', props.size === 'small' ? 'bt-toggle-group--small' : '']\n    .filter(Boolean)\n    .join(' '),\n);\n</script>\n\n<template>\n  <div :class=\"groupClass\" role=\"group\" data-testid=\"bt-toggle-group\">\n    <BTToggle\n      v-for=\"item in items\"\n      :key=\"String(item.value)\"\n      :label=\"item.label\"\n      :pressed=\"isPressed(item)\"\n      :variant=\"variant\"\n      :size=\"size\"\n      :disabled=\"disabled || !!item.disabled\"\n      @change=\"handleToggle(item)\"\n    />\n  </div>\n</template>\n"
    }
  ]
}