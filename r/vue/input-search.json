    {
      "path": "BTInputSearch.css",
      "target": "@ui/input-search/BTInputSearch.css",
      "type": "registry:ui",
      "content": "/* Clear-button slide-in / slide-out animation (inlined from BTInputClear.css) */\r\n.bt-input-clear-enter-active,\r\n.bt-input-clear-leave-active {\r\n  transition: opacity 150ms cubic-bezier(0.4, 0, 0.2, 1),\r\n              transform 150ms cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n\r\n.bt-input-clear-enter-from,\r\n.bt-input-clear-leave-to {\r\n  opacity: 0;\r\n  transform: translateX(6px);\r\n}\r\n\r\n.bt-input-clear-enter-to,\r\n.bt-input-clear-leave-from {\r\n  opacity: 1;\r\n  transform: translateX(0);\r\n}\r\n\r\n.bt-input-search {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--space-xs);\r\n  width: 100%;\r\n  font-family: var(--typography-font-family-sans);\r\n}\r\n\r\n/* The visual field row */\r\n.bt-input-search__field {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-sm);\r\n  padding: 12px 8px;\r\n  border: 1px solid var(--border-primary);\r\n  border-radius: var(--radius-sm);\r\n  background: var(--bg-primary);\r\n  transition: border-color 150ms ease;\r\n  box-sizing: border-box;\r\n  width: 100%;\r\n}\r\n\r\n.bt-input-search__field--focused {\r\n  border-color: var(--color-brand-primary);\r\n}\r\n\r\n.bt-input-search__field--error {\r\n  border-color: var(--text-error);\r\n}\r\n\r\n.bt-input-search__field--disabled {\r\n  background: var(--bg-subtle);\r\n  cursor: not-allowed;\r\n}\r\n\r\n/* Icon container — controls icon color via 'color' property */\r\n.bt-input-search__icon {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 16px;\r\n  height: 16px;\r\n  flex-shrink: 0;\r\n  color: var(--text-secondary);\r\n}\r\n\r\n.bt-input-search__icon--disabled {\r\n  color: var(--text-disabled);\r\n}\r\n\r\n/* The actual <input> element */\r\n.bt-input-search__input {\r\n  flex: 1;\r\n  min-width: 0;\r\n  border: none;\r\n  outline: none;\r\n  background: transparent;\r\n  font-family: var(--typography-font-family-sans);\r\n  font-size: var(--typography-font-size-xs);\r\n  font-weight: 500;\r\n  line-height: var(--typography-line-height-xs);\r\n  letter-spacing: 0;\r\n  color: var(--text-primary);\r\n  padding: 0;\r\n}\r\n\r\n.bt-input-search__input::placeholder {\r\n  color: var(--text-secondary);\r\n}\r\n\r\n.bt-input-search__input:disabled {\r\n  color: var(--text-disabled);\r\n  cursor: not-allowed;\r\n}\r\n\r\n.bt-input-search__input--error {\r\n  color: var(--text-error);\r\n}\r\n\r\n/* Suppress native browser ✕ on type=\"search\" */\r\n.bt-input-search__input[type=\"search\"]::-webkit-search-cancel-button {\r\n  -webkit-appearance: none;\r\n  appearance: none;\r\n}\r\n\r\n/* Clear / cancel button — right side, shown when focused + has value */\r\n/* Visibility driven by v-if + <Transition name=\"bt-input-clear\"> — no toggle class needed */\r\n.bt-input-search__cancel {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 16px;\r\n  height: 16px;\r\n  flex-shrink: 0;\r\n  border: none;\r\n  background: none;\r\n  padding: 0;\r\n  cursor: pointer;\r\n  color: var(--icon-primary);\r\n}\r\n\r\n/* Validation / helper text row */\r\n.bt-input-search__validation {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: var(--space-xs);\r\n  font-family: var(--typography-font-family-sans);\r\n  font-size: var(--typography-font-size-xs);\r\n  font-weight: 500;\r\n  line-height: var(--typography-line-height-xs);\r\n  letter-spacing: 0;\r\n  color: var(--text-secondary);\r\n}\r\n\r\n.bt-input-search__validation--error {\r\n  color: var(--text-error);\r\n}\r\n\r\n/* ── RTL: cursor/caret at inline-start (right in RTL) ──────────────────── */\r\n[dir=\"rtl\"] .bt-input-search__input { direction: rtl; }\r\n"
    },
    {
      "path": "BTInputSearch.types.ts",
      "target": "@ui/input-search/BTInputSearch.types.ts",
      "type": "registry:ui",
      "content": "export interface BTInputSearchProps {\r\n  modelValue?: string;\r\n  /** Field name — when set inside a `<BTForm>`, auto-wires value/error. */\r\n  name?: string;\r\n  placeholder?: string;\r\n  disabled?: boolean;\r\n  errorText?: string;\r\n  helperText?: string;\r\n  validator?: (value: string) => string | null;\r\n}\r\n"
    },
    {
      "path": "BTInputSearch.vue",
      "target": "@ui/input-search/BTInputSearch.vue",
      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\r\n/**\r\n * BTInputSearch — standalone search field.\r\n *\r\n * @example\r\n * <BTInputSearch\r\n *   v-model=\"query\"\r\n *   placeholder=\"Search products...\"\r\n *   helper-text=\"Minimum 3 characters\"\r\n *   :validator=\"(v) => v.length < 3 ? 'Enter at least 3 characters' : null\"\r\n *   @search=\"onSearch\"\r\n *   @clear=\"onClear\"\r\n * />\r\n */\r\nimport { ref, computed, inject, getCurrentInstance } from 'vue';\r\nimport './BTInputSearch.css';\r\nimport type { BTInputSearchProps } from './BTInputSearch.types';\r\n\r\nconst props = withDefaults(defineProps<BTInputSearchProps>(), {\r\n  placeholder: 'Search',\r\n  disabled: false,\r\n});\r\n\r\nconst emit = defineEmits<{\r\n  'update:modelValue': [value: string];\r\n  search: [value: string];\r\n  clear: [];\r\n}>();\r\n\r\nconst isFocused = ref(false);\r\nconst errorInternal = ref<string | null>(null);\r\n\r\nconst _uid = getCurrentInstance()?.uid;\r\nconst fieldId = computed(() => `bt-input-search-${_uid}`);\r\n\r\n// ── BTForm wrapping (optional) ────────────────────────────────────\r\nconst formValues   = inject<Record<string, unknown> | null>('bt-form-values', null);\r\nconst formErrorFor = inject<((name: string) => string | null) | null>('bt-form-error-for', null);\r\nconst formSetField = inject<((name: string, v: unknown) => void) | null>('bt-form-set-field', null);\r\nconst formTouch    = inject<((name: string) => void) | null>('bt-form-touch', null);\r\nconst isInForm     = computed(() => formValues !== null && typeof props.name === 'string');\r\nconst formValue    = computed(() =>\r\n  isInForm.value ? (formValues![props.name as string] as string | undefined) : undefined\r\n);\r\nconst formError    = computed(() =>\r\n  isInForm.value && formErrorFor ? formErrorFor(props.name as string) : null\r\n);\r\nconst resolvedValue = computed<string | undefined>(() => props.modelValue ?? formValue.value);\r\n\r\nconst activeError = computed(() => props.errorText ?? errorInternal.value ?? formError.value ?? null);\r\nconst hasError = computed(() => !!activeError.value);\r\nconst resolvedRequired = computed(() => false);\r\nconst isEmpty = computed(() => !resolvedValue.value);\r\nconst showCancel = computed(() => isFocused.value && !isEmpty.value && !props.disabled);\r\n\r\nfunction onInput(e: Event) {\r\n  errorInternal.value = null;\r\n  const next = (e.target as HTMLInputElement).value;\r\n  emit('update:modelValue', next);\r\n  if (isInForm.value && formSetField && props.name) formSetField(props.name, next);\r\n}\r\n\r\nfunction onKeydown(e: KeyboardEvent) {\r\n  if (e.key === 'Enter') {\r\n    emit('search', (e.target as HTMLInputElement).value);\r\n  }\r\n}\r\n\r\nfunction onClear() {\r\n  emit('update:modelValue', '');\r\n  if (isInForm.value && formSetField && props.name) formSetField(props.name, '');\r\n  emit('clear');\r\n  errorInternal.value = null;\r\n}\r\n\r\nfunction onFocus() { isFocused.value = true; }\r\nfunction onBlur() {\r\n  isFocused.value = false;\r\n  if (isInForm.value && formTouch && props.name) formTouch(props.name);\r\n}\r\n\r\nfunction validate(): boolean {\r\n  if (!props.validator) return true;\r\n  const result = props.validator(props.modelValue ?? '');\r\n  errorInternal.value = result ?? null;\r\n  return result === null;\r\n}\r\n\r\ndefineExpose({ validate });\r\n</script>\r\n\r\n<template>\r\n  <div class=\"bt-input-search\">\r\n    <!-- Field row -->\r\n    <div\r\n      class=\"bt-input-search__field\"\r\n      :class=\"{\r\n        'bt-input-search__field--focused': isFocused && !activeError,\r\n        'bt-input-search__field--error': !!activeError,\r\n        'bt-input-search__field--disabled': disabled,\r\n      }\"\r\n    >\r\n      <!-- Search icon -->\r\n      <span\r\n        class=\"bt-input-search__icon\"\r\n        :class=\"{ 'bt-input-search__icon--disabled': disabled }\"\r\n      >\r\n        <svg width=\"12\" height=\"12\" viewBox=\"0 0 11.7167 11.7167\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n          <path d=\"M4.33333 8.66667C3.12222 8.66667 2.09722 8.24722 1.25833 7.40833C0.419444 6.56944 0 5.54444 0 4.33333C0 3.12222 0.419444 2.09722 1.25833 1.25833C2.09722 0.419444 3.12222 0 4.33333 0C5.54444 0 6.56944 0.419444 7.40833 1.25833C8.24722 2.09722 8.66667 3.12222 8.66667 4.33333C8.66667 4.82222 8.58889 5.28333 8.43333 5.71667C8.27778 6.15 8.06667 6.53333 7.8 6.86667L11.5333 10.6C11.6556 10.7222 11.7167 10.8778 11.7167 11.0667C11.7167 11.2556 11.6556 11.4111 11.5333 11.5333C11.4111 11.6556 11.2556 11.7167 11.0667 11.7167C10.8778 11.7167 10.7222 11.6556 10.6 11.5333L6.86667 7.8C6.53333 8.06667 6.15 8.27778 5.71667 8.43333C5.28333 8.58889 4.82222 8.66667 4.33333 8.66667ZM4.33333 7.33333C5.16667 7.33333 5.875 7.04167 6.45833 6.45833C7.04167 5.875 7.33333 5.16667 7.33333 4.33333C7.33333 3.5 7.04167 2.79167 6.45833 2.20833C5.875 1.625 5.16667 1.33333 4.33333 1.33333C3.5 1.33333 2.79167 1.625 2.20833 2.20833C1.625 2.79167 1.33333 3.5 1.33333 4.33333C1.33333 5.16667 1.625 5.875 2.20833 6.45833C2.79167 7.04167 3.5 7.33333 4.33333 7.33333Z\" fill=\"currentColor\"/>\r\n        </svg>\r\n      </span>\r\n\r\n      <!-- Input -->\r\n      <input\r\n        :id=\"fieldId\"\r\n        class=\"bt-input-search__input\"\r\n        :class=\"{ 'bt-input-search__input--error': !!activeError && !disabled }\"\r\n        type=\"search\"\r\n        :name=\"name\"\r\n        :value=\"resolvedValue ?? ''\"\r\n        :placeholder=\"placeholder\"\r\n        :disabled=\"disabled\"\r\n        :aria-invalid=\"hasError || undefined\"\r\n        :aria-required=\"resolvedRequired || undefined\"\r\n        @input=\"onInput\"\r\n        @keydown=\"onKeydown\"\r\n        @focus=\"onFocus\"\r\n        @blur=\"onBlur\"\r\n      />\r\n\r\n      <!-- Cancel/clear button — v-if + Transition for smooth slide-from-right -->\r\n      <Transition name=\"bt-input-clear\">\r\n        <button\r\n          v-if=\"showCancel\"\r\n          type=\"button\"\r\n          class=\"bt-input-search__cancel\"\r\n          tabindex=\"-1\"\r\n          aria-label=\"Clear search\"\r\n          @pointerdown.prevent=\"onClear\"\r\n        >\r\n          <svg width=\"13\" height=\"13\" viewBox=\"0 0 13.3333 13.3333\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n            <path d=\"M6.66667 7.6L8.6 9.53333C8.72222 9.65555 8.87778 9.71667 9.06667 9.71667C9.25555 9.71667 9.41111 9.65555 9.53333 9.53333C9.65555 9.41111 9.71667 9.25555 9.71667 9.06667C9.71667 8.87778 9.65555 8.72222 9.53333 8.6L7.6 6.66667L9.53333 4.73333C9.65555 4.61111 9.71667 4.45556 9.71667 4.26667C9.71667 4.07778 9.65555 3.92222 9.53333 3.8C9.41111 3.67778 9.25555 3.61667 9.06667 3.61667C8.87778 3.61667 8.72222 3.67778 8.6 3.8L6.66667 5.73333L4.73333 3.8C4.61111 3.67778 4.45556 3.61667 4.26667 3.61667C4.07778 3.61667 3.92222 3.67778 3.8 3.8C3.67778 3.92222 3.61667 4.07778 3.61667 4.26667C3.61667 4.45556 3.67778 4.61111 3.8 4.73333L5.73333 6.66667L3.8 8.6C3.67778 8.72222 3.61667 8.87778 3.61667 9.06667C3.61667 9.25555 3.67778 9.41111 3.8 9.53333C3.92222 9.65555 4.07778 9.71667 4.26667 9.71667C4.45556 9.71667 4.61111 9.65555 4.73333 9.53333L6.66667 7.6ZM6.66667 13.3333C5.74444 13.3333 4.87778 13.1583 4.06667 12.8083C3.25556 12.4583 2.55 11.9833 1.95 11.3833C1.35 10.7833 0.875 10.0778 0.525 9.26667C0.175 8.45556 0 7.58889 0 6.66667C0 5.74444 0.175 4.87778 0.525 4.06667C0.875 3.25556 1.35 2.55 1.95 1.95C2.55 1.35 3.25556 0.875 4.06667 0.525C4.87778 0.175 5.74444 0 6.66667 0C7.58889 0 8.45556 0.175 9.26667 0.525C10.0778 0.875 10.7833 1.35 11.3833 1.95C11.9833 2.55 12.4583 3.25556 12.8083 4.06667C13.1583 4.87778 13.3333 5.74444 13.3333 6.66667C13.3333 7.58889 13.1583 8.45556 12.8083 9.26667C12.4583 10.0778 11.9833 10.7833 11.3833 11.3833C10.7833 11.9833 10.0778 12.4583 9.26667 12.8083C8.45556 13.1583 7.58889 13.3333 6.66667 13.3333Z\" fill=\"currentColor\"/>\r\n          </svg>\r\n        </button>\r\n      </Transition>\r\n    </div>\r\n\r\n    <!-- Validation / helper text -->\r\n    <div\r\n      v-if=\"activeError || helperText\"\r\n      class=\"bt-input-search__validation\"\r\n      :class=\"{ 'bt-input-search__validation--error': !!activeError }\"\r\n      :role=\"hasError ? 'alert' : undefined\"\r\n    >\r\n      {{ activeError ?? helperText }}\r\n    </div>\r\n  </div>\r\n</template>\r\n"
    },
