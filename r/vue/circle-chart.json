    {
      "path": "BTCircleChart.css",
      "target": "@ui/BTCircleChart.css",
      "type": "registry:ui",
      "content": "/* BTCircleChart — circle chart wrapper */\n\n.bt-circle-chart {\n  position: relative;\n  display: inline-block;\n}\n\n.bt-circle-chart__rounded-svg {\n  display: block;\n  overflow: visible;\n}\n\n.bt-circle-chart__rounded-arc {\n  paint-order: stroke fill;\n}\n\n.bt-circle-chart__rounded-arc-border {\n  paint-order: stroke fill;\n}\n\n/* Connector lines SVG overlay */\n.bt-circle-chart__connectors {\n  position: absolute;\n  inset: 0;\n  overflow: visible;\n  pointer-events: none;\n}\n\n.bt-circle-chart__connector-line {\n  stroke: var(--border-primary);\n  stroke-width: 1;\n  fill: none;\n}\n\n/* External badge labels overlay */\n.bt-circle-chart__labels {\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n}\n\n.bt-circle-chart__badge {\n  position: absolute;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  transform: translate(-50%, -50%);\n  text-align: center;\n  line-height: 1.4;\n}\n\n.bt-circle-chart__badge-label {\n  font-size: var(--typography-font-size-2xs);\n  font-weight: 500;\n  color: var(--text-secondary);\n  font-family: var(--typography-font-family-sans, \"Geist\", system-ui);\n}\n\n.bt-circle-chart__badge-value {\n  font-size: var(--typography-font-size-2xs);\n  font-weight: 700;\n  color: var(--text-primary);\n  font-family: var(--typography-font-family-sans, \"Geist\", system-ui);\n}\n\n/* DonutRounded: rounded segment ends via SVG stroke-linecap */\n.bt-circle-chart--donut-rounded .apexcharts-pie-area {\n  stroke-linecap: round !important;\n  stroke-linejoin: round !important;\n  paint-order: stroke fill !important;\n}\n\n.bt-circle-chart--donut-rounded .apexcharts-series path {\n  stroke-linecap: round !important;\n  stroke-linejoin: round !important;\n}\n\n/* Remove ApexCharts default tooltip chrome */\n.bt-circle-chart .apexcharts-tooltip {\n  background: transparent !important;\n  border: none !important;\n  box-shadow: none !important;\n  overflow: visible !important;\n}\n"
    },
    {
      "path": "BTCircleChart.types.ts",
      "target": "@ui/BTCircleChart.types.ts",
      "type": "registry:ui",
      "content": "export type { BTCircleSection } from '../internal/chart.types';\n\nexport type BTCircleChartVariant = 'pie' | 'donut' | 'donutRounded';\n"
    },
    {
      "path": "BTCircleChart.vue",
      "target": "@ui/BTCircleChart.vue",
      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\n/**\n * BTCircleChart — pie / donut / donutRounded chart molecule (ApexCharts wrapper).\n *\n * Figma node 3404:1813 · M - CircleChart\n *\n * External badge labels (Label + %) are positioned around the ring via\n * computed polar coordinates, matching the Flutter badge-offset approach.\n *\n * @example\n * ```ts\n * // Pie\n * <BTCircleChart :sections=\"[{value:40,color:'#0EA5E9',label:'A'}]\" />\n *\n * // Donut\n * <BTCircleChart :sections=\"sections\" variant=\"donut\" />\n *\n * // Donut Rounded (rounded ends + gap between segments)\n * <BTCircleChart :sections=\"sections\" variant=\"donutRounded\" />\n * ```\n */\nimport './BTCircleChart.css';\nimport '../internal/chart-tooltip.css';\nimport { computed } from 'vue';\nimport VueApexCharts from 'vue3-apexcharts';\nimport type { ApexOptions } from 'apexcharts';\nimport type { BTCircleSection, BTCircleChartVariant } from './BTCircleChart.types';\nimport { buildTooltipHtml } from '../internal/chart-tooltip';\nimport { btChartBase } from '../internal/chart-apex.utils';\n\ninterface RoundedArcSegment {\n  color: string;\n  d: string;\n}\n\nfunction polarToCartesian(cx: number, cy: number, radius: number, angleDeg: number) {\n  const angleRad = ((angleDeg - 90) * Math.PI) / 180;\n  return {\n    x: cx + radius * Math.cos(angleRad),\n    y: cy + radius * Math.sin(angleRad),\n  };\n}\n\nfunction buildRoundedArcPath(\n  cx: number,\n  cy: number,\n  radius: number,\n  startAngle: number,\n  endAngle: number,\n) {\n  const start = polarToCartesian(cx, cy, radius, startAngle);\n  const end = polarToCartesian(cx, cy, radius, endAngle);\n  const delta = ((endAngle - startAngle) % 360 + 360) % 360;\n  const largeArcFlag = delta > 180 ? 1 : 0;\n  return `M ${start.x} ${start.y} A ${radius} ${radius} 0 ${largeArcFlag} 1 ${end.x} ${end.y}`;\n}\n\nconst props = withDefaults(\n  defineProps<{\n    sections: BTCircleSection[];\n    variant?: BTCircleChartVariant;\n    /** Width/height of the chart container in px */\n    size?: number;\n  }>(),\n  {\n    variant: 'pie',\n    size: 208,\n  },\n);\n\nconst isPie          = computed(() => props.variant === 'pie');\nconst isDonut        = computed(() => props.variant === 'donut');\nconst isDonutRounded = computed(() => props.variant === 'donutRounded');\n\n// Donut hole size as percentage:\n// pie: 0% · donut: 51.4% (36/70*100) · donutRounded: 57.1% (40/70*100)\nconst donutSize = computed<string>(() => {\n  if (isPie.value) return '0%';\n  if (isDonutRounded.value) return '60%';\n  return '58%';\n});\n\nconst total = computed(() =>\n  props.sections.reduce((s, sec) => s + sec.value, 0),\n);\n\nconst roundedArcSegments = computed<RoundedArcSegment[]>(() => {\n  if (!isDonutRounded.value || total.value <= 0) return [];\n\n  const cx = props.size / 2;\n  const cy = props.size / 2;\n  const radius = props.size * 0.305;\n  const gapAngle = 9;\n\n  let currentAngle = -90;\n  return props.sections.map((section) => {\n    const sweep = (section.value / total.value) * 360;\n    const safeSweep = Math.max(sweep - gapAngle, 0);\n    const startAngle = currentAngle + gapAngle / 2;\n    const endAngle = startAngle + safeSweep;\n    currentAngle += sweep;\n\n    return {\n      color: section.color,\n      d: buildRoundedArcPath(cx, cy, radius, startAngle, endAngle),\n    };\n  });\n});\n\n// ── External badge label positions + connector lines ──────────────────────────\n//\n// outerR  = rendered ring outer edge (~90% of half-size, accounting for ApexCharts padding)\n// Connector line: outerR+4 → outerR+28 (4px gap from ring, 24px line)\n// Badge center: outerR+34 (6px after line end)\n// ApexCharts starts at -90° (top). Cumulative angle walks clockwise.\n\nconst badgePositions = computed(() => {\n  if (total.value === 0) return [];\n  const cx     = props.size / 2;\n  const cy     = props.size / 2;\n  const outerR = props.size / 2 * 0.84;\n  const lineR1 = outerR + (isPie.value ? 10 : 6);\n  const lineR2 = outerR + 26;\n  const badgeR = outerR + 40;\n\n  let cumAngle = -90;\n  return props.sections.map((sec) => {\n    const sweep = (sec.value / total.value) * 360;\n    const mid   = cumAngle + sweep / 2;\n    const rad   = (mid * Math.PI) / 180;\n    cumAngle   += sweep;\n    const cosA  = Math.cos(rad);\n    const sinA  = Math.sin(rad);\n    return {\n      label:  sec.label ?? '',\n      pct:    `${((sec.value / total.value) * 100).toFixed(0)}%`,\n      // badge center\n      x:  cx + badgeR * cosA,\n      y:  cy + badgeR * sinA,\n      // connector line endpoints\n      lx1: cx + lineR1 * cosA,\n      ly1: cy + lineR1 * sinA,\n      lx2: cx + lineR2 * cosA,\n      ly2: cy + lineR2 * sinA,\n    };\n  });\n});\n\n// ── ApexCharts options ────────────────────────────────────────────────────────\n\nconst options = computed<ApexOptions>(() => ({\n  chart: {\n    ...btChartBase(),\n    type: 'donut',\n    width: props.size,\n    height: props.size,\n  },\n  plotOptions: {\n    pie: {\n      startAngle: -90,\n      endAngle: 270,\n      customScale: isPie.value ? 0.96 : isDonutRounded.value ? 0.88 : 0.9,\n      donut: {\n        size: donutSize.value,\n      },\n    },\n  },\n  // Donut is continuous. DonutRounded adds subtle gaps so rounded ends read clearly.\n  stroke: isPie.value\n    ? { show: false }\n    : isDonut.value\n      ? { show: false }\n      : { show: true, width: 10, colors: ['var(--bg-primary)'] },\n  dataLabels: { enabled: false },\n  legend:     { show: false },\n  colors: props.sections.map((s) => s.color),\n  labels: props.sections.map((s) => s.label ?? ''),\n  tooltip: {\n    custom({ seriesIndex }: { seriesIndex: number }) {\n      const sec = props.sections[seriesIndex];\n      if (!sec) return buildTooltipHtml(null, []);\n      const pct   = total.value > 0\n        ? ((sec.value / total.value) * 100).toFixed(0)\n        : '0';\n      const title = sec.label\n        ? `${sec.label} ${pct}%`\n        : `${pct}%`;\n      return buildTooltipHtml(title, [], { placement: 'none' });\n    },\n  },\n}));\n\nconst apexSeries = computed(() => props.sections.map((s) => s.value));\nconst roundedStrokeWidth = computed(() => props.size * 0.122);\nconst roundedBorderWidth = computed(() => props.size * 0.148);\n</script>\n\n<template>\n  <div\n    class=\"bt-circle-chart\"\n    :class=\"{ 'bt-circle-chart--donut-rounded': variant === 'donutRounded' }\"\n    :style=\"{ width: `${size}px`, height: `${size}px` }\"\n  >\n    <svg\n      v-if=\"variant === 'donutRounded'\"\n      class=\"bt-circle-chart__rounded-svg\"\n      :width=\"size\"\n      :height=\"size\"\n      :viewBox=\"`0 0 ${size} ${size}`\"\n      aria-hidden=\"true\"\n    >\n      <path\n        v-for=\"(segment, index) in roundedArcSegments\"\n        :key=\"index\"\n        :d=\"segment.d\"\n        fill=\"none\"\n        stroke=\"var(--bg-primary)\"\n        :stroke-width=\"roundedBorderWidth\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        class=\"bt-circle-chart__rounded-arc-border\"\n      />\n      <path\n        v-for=\"(segment, index) in roundedArcSegments\"\n        :key=\"`fill-${index}`\"\n        :d=\"segment.d\"\n        fill=\"none\"\n        :stroke=\"segment.color\"\n        :stroke-width=\"roundedStrokeWidth\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        class=\"bt-circle-chart__rounded-arc\"\n      />\n    </svg>\n\n    <VueApexCharts\n      v-else\n      type=\"donut\"\n      :width=\"size\"\n      :height=\"size\"\n      :options=\"options\"\n      :series=\"apexSeries\"\n    />\n\n    <!-- Connector lines from ring edge to badges -->\n    <svg\n      class=\"bt-circle-chart__connectors\"\n      :style=\"{ width: `${size}px`, height: `${size}px` }\"\n      aria-hidden=\"true\"\n    >\n      <line\n        v-for=\"(badge, i) in badgePositions\"\n        :key=\"i\"\n        :x1=\"badge.lx1\"\n        :y1=\"badge.ly1\"\n        :x2=\"badge.lx2\"\n        :y2=\"badge.ly2\"\n        class=\"bt-circle-chart__connector-line\"\n      />\n    </svg>\n\n    <!-- External badge labels -->\n    <div class=\"bt-circle-chart__labels\">\n      <div\n        v-for=\"(badge, i) in badgePositions\"\n        :key=\"i\"\n        class=\"bt-circle-chart__badge\"\n        :style=\"{ left: `${badge.x}px`, top: `${badge.y}px` }\"\n      >\n        <span v-if=\"badge.label\" class=\"bt-circle-chart__badge-label\">\n          {{ badge.label }}\n        </span>\n        <span class=\"bt-circle-chart__badge-value\">{{ badge.pct }}</span>\n      </div>\n    </div>\n  </div>\n</template>\n"
    }
  ]
}