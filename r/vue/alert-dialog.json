  "files": [
    {
      "path": "BTAlertDialog.css",
      "target": "@ui/alert-dialog/BTAlertDialog.css",
      "type": "registry:ui",
      "content": "/* BTAlertDialog — Figma nodes 2519-1822 (web D) + 2519-2209 (mobile M → Flutter) */\n/* All CSS vars verified against packages/tokens/platforms/web/bspace/dist/styles.css */\n\n/* ── Overlay (backdrop) ──────────────────────────────────────────────────────── */\n\n.bt-alert-dialog-overlay {\n  position: fixed;\n  inset: 0;\n  z-index: 9100;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(0, 0, 0, 0.5);\n  animation: bt-alert-dialog-overlay-in 150ms ease;\n}\n\n@keyframes bt-alert-dialog-overlay-in {\n  from { opacity: 0; }\n  to   { opacity: 1; }\n}\n\n/* ── Dialog card ─────────────────────────────────────────────────────────────── */\n\n.bt-alert-dialog {\n  background: var(--bg-primary);\n  border-radius: var(--radius-md);\n  box-shadow: var(--shadow-elevation-lg);\n  width: 500px;\n  padding: 24px var(--space-lg);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-xl);\n  box-sizing: border-box;\n  animation: bt-alert-dialog-in 150ms ease;\n}\n\n@keyframes bt-alert-dialog-in {\n  from { opacity: 0; transform: scale(0.95); }\n  to   { opacity: 1; transform: scale(1); }\n}\n\n/* ── Content ─────────────────────────────────────────────────────────────────── */\n\n.bt-alert-dialog__content {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-lg);\n  width: 100%;\n}\n\n.bt-alert-dialog__media {\n  width: 64px;\n  height: 64px;\n  padding: 10px;\n  background: var(--bg-subtle);\n  border-radius: var(--radius-lg);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  box-sizing: border-box;\n}\n\n.bt-alert-dialog__icon {\n  width: 32px;\n  height: 32px;\n  display: block;\n  flex-shrink: 0;\n  /* SVG has fill=\"#64748B\" (text-secondary) — no color override needed */\n}\n\n.bt-alert-dialog__text {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-xs);\n  text-align: center;\n  width: 100%;\n}\n\n.bt-alert-dialog__title {\n  font-size: var(--typography-font-size-lg);\n  font-weight: 700;\n  line-height: var(--typography-line-height-md);\n  color: var(--text-primary);\n  margin: 0;\n}\n\n.bt-alert-dialog__description {\n  font-size: var(--typography-font-size-sm);\n  font-weight: 500;\n  line-height: var(--typography-line-height-xs);\n  color: var(--text-secondary);\n  margin: 0;\n}\n\n.bt-alert-dialog__slot {\n  width: 100%;\n}\n\n.bt-alert-dialog__actions {\n  display: flex;\n  gap: var(--space-sm);\n  align-items: center;\n  justify-content: center;\n}\n"
    },
    {
      "path": "BTAlertDialog.types.ts",
      "target": "@ui/alert-dialog/BTAlertDialog.types.ts",
      "type": "registry:ui",
      "content": "// BTAlertDialog types — Figma node 2519-1822 (web D, 500px).\n\nexport type BTAlertDialogVariant =\n  | 'success'\n  | 'warning'\n  | 'confirmation'\n  | 'info'\n  | 'delete';\n\nexport interface BTAlertDialogProps {\n  // Visual variant — controls icon, confirm button colour, and default label.\n  variant: BTAlertDialogVariant;\n  // Primary heading text.\n  title: string;\n  // Supporting description text.\n  description: string;\n  // Overrides the default confirm label ('Continue' or 'Delete').\n  confirmLabel?: string;\n  // Label for the cancel button. @default 'Cancel'\n  cancelLabel?: string;\n  // Whether to show the cancel (2nd) button. @default true\n  has2ndButton?: boolean;\n  // Controls dialog open/close state (v-model). @default false\n  modelValue?: boolean;\n  // Close dialog when backdrop is clicked. @default true\n  closeOnOverlayClick?: boolean;\n}\n"
    },
    {
      "path": "BTAlertDialog.vue",
      "target": "@ui/alert-dialog/BTAlertDialog.vue",
      "type": "registry:ui",
      "content": "<script setup lang=\"ts\">\n// BTAlertDialog — modal confirmation dialog rendered as a centered overlay.\n// Figma: D node 2519-1822 (web 500px). Mobile Flutter → M node 2519-2209.\n//\n// Usage:\n//   const open = ref(false)\n//   <BTButton label=\"Delete\" @click=\"open = true\" />\n//   <BTAlertDialog v-model=\"open\" variant=\"delete\" title=\"Delete?\" description=\"...\" @confirm=\"doDelete\" />\nimport './BTAlertDialog.css'\nimport { computed, ref, useSlots, onMounted } from 'vue'\nimport type { BTAlertDialogProps, BTAlertDialogVariant } from './BTAlertDialog.types'\nimport BTButton from '../button/BTButton.vue'\n\nimport iconVerifiedUser  from './icons/verified_user.svg'\nimport iconE911          from './icons/e911_emergency.svg'\nimport iconSirenQuestion from './icons/siren_question.svg'\nimport iconLightbulb     from './icons/lightbulb.svg'\nimport iconDelete        from './icons/delete.svg'\n\nconst ICONS: Record<BTAlertDialogVariant, string> = {\n  success:      iconVerifiedUser,\n  warning:      iconE911,\n  confirmation: iconSirenQuestion,\n  info:         iconLightbulb,\n  delete:       iconDelete,\n}\n\nconst props = withDefaults(defineProps<BTAlertDialogProps>(), {\n  cancelLabel: 'Cancel',\n  has2ndButton: true,\n  modelValue: false,\n  closeOnOverlayClick: true,\n})\n\nconst emit = defineEmits<{\n  'update:modelValue': [value: boolean]\n  confirm: []\n  cancel: []\n}>()\n\nconst slots = useSlots()\nconst hasSlot = computed(() => Boolean(slots.default))\n\nconst confirmVariant = computed(() =>\n  props.variant === 'delete' ? 'destructive' : 'primary'\n)\n\nconst confirmLabel = computed(() =>\n  props.confirmLabel ?? (props.variant === 'delete' ? 'Delete' : 'Continue')\n)\n\nfunction closeOverlay() {\n  emit('update:modelValue', false)\n}\n\nfunction handleCancel() {\n  emit('cancel')\n  closeOverlay()\n}\n\nconst markerEl = ref<HTMLSpanElement | null>(null)\nconst dir = computed(() => {\n  if (!markerEl.value) return 'ltr'\n  return getComputedStyle(markerEl.value).direction || 'ltr'\n})\n</script>\n\n<template>\n  <span ref=\"markerEl\" style=\"display: none\" />\n  <Teleport to=\"body\">\n    <div\n      v-if=\"modelValue\"\n      class=\"bt-alert-dialog-overlay\"\n      :dir=\"dir\"\n      role=\"presentation\"\n      @click.self=\"closeOnOverlayClick && closeOverlay()\"\n    >\n      <div\n        class=\"bt-alert-dialog\"\n        role=\"alertdialog\"\n        aria-modal=\"true\"\n        :aria-labelledby=\"`bt-ad-title-${variant}`\"\n        :aria-describedby=\"`bt-ad-desc-${variant}`\"\n      >\n        <div class=\"bt-alert-dialog__content\">\n          <div class=\"bt-alert-dialog__media\" aria-hidden=\"true\">\n            <img :src=\"ICONS[variant]\" class=\"bt-alert-dialog__icon\" alt=\"\" />\n          </div>\n          <div class=\"bt-alert-dialog__text\">\n            <p :id=\"`bt-ad-title-${variant}`\" class=\"bt-alert-dialog__title\">{{ title }}</p>\n            <p :id=\"`bt-ad-desc-${variant}`\" class=\"bt-alert-dialog__description\">{{ description }}</p>\n          </div>\n          <div v-if=\"hasSlot\" class=\"bt-alert-dialog__slot\">\n            <slot />\n          </div>\n        </div>\n        <div class=\"bt-alert-dialog__actions\">\n          <BTButton\n            v-if=\"has2ndButton\"\n            :label=\"cancelLabel\"\n            variant=\"secondary-light\"\n            @click=\"handleCancel\"\n          />\n          <BTButton\n            :label=\"confirmLabel\"\n            :variant=\"confirmVariant\"\n            @click=\"emit('confirm')\"\n          />\n        </div>\n      </div>\n    </div>\n  </Teleport>\n</template>\n"
    },
